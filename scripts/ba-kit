#!/usr/bin/env bash

set -euo pipefail

CLI_NAME="ba-kit"
DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
STATE_DIR="${DATA_HOME}/ba-kit"
MANIFEST_DIR="${STATE_DIR}/installations"
UPDATE_CACHE_DIR="${STATE_DIR}/update-check"
UPDATE_CHECK_TTL_SECONDS="${BA_KIT_UPDATE_CHECK_TTL_SECONDS:-21600}"

usage() {
  cat <<'EOF'
Usage:
  ba-kit doctor
  ba-kit update
  ba-kit resolve [--slug <slug>] [--date <YYMMDD-HHmm>] [--module <module_slug>]
  ba-kit next [--slug <slug>] [--date <YYMMDD-HHmm>] [--module <module_slug>]
  ba-kit check-prereq <command> [--slug <slug>] [--date <YYMMDD-HHmm>] [--module <module_slug>]
  ba-kit template-section <template> <group>
  ba-kit source-extract <file> [--slug <slug>] [--date <YYMMDD-HHmm>] [--chunk-chars <n>] [--copy-raw] [--promote]
  ba-kit design-snapshot [--slug <slug>] [--design-doc <path>]
  ba-kit stitch-state <init|show|upsert> --slug <slug> [options]
  ba-kit chunk-write --file <target_file>
  ba-kit status [--slug <slug>] [--date <YYMMDD-HHmm>] [--module <module_slug>]

Commands:
  doctor          Check BA-kit runtime readiness, installed manifests, and optional MCP/tool dependencies.
  update          Fast-forward pull the installed BA-kit source repo and rerun installed runtime installers.
  resolve         Resolve the exact slug/date/module target from the modular tree.
  next            Recommend the next BA-kit command for the resolved modular artifact set.
  check-prereq    Validate the exact prerequisite artifacts for a BA command.
  template-section  Print only the requested template group from templates/manifest.json.
  source-extract  Extract a source file into staged cache and optionally promote it into 00_source.
  design-snapshot Legacy utility: generate a compact snapshot from designs/{slug}/DESIGN.md.
  stitch-state    Legacy utility: manage old Stitch-backed state files.
  chunk-write     Append incoming STDIN safely to <target_file> for large artifact mitigation.
  status          Inspect BA-kit modular artifacts and delegated worker trackers from the registered source repo.
EOF
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

read_manifest_value() {
  local manifest_path="$1"
  local key="$2"

  awk -F= -v target_key="${key}" '
    $1 == target_key {
      sub(/^[[:space:]]+/, "", $2)
      sub(/[[:space:]]+$/, "", $2)
      print $2
      exit
    }
  ' "${manifest_path}"
}

collect_installations() {
  if [[ ! -d "${MANIFEST_DIR}" ]]; then
    return 0
  fi

  local manifest_path runtime repo
  for manifest_path in "${MANIFEST_DIR}"/*.env; do
    [[ -f "${manifest_path}" ]] || continue
    runtime="$(read_manifest_value "${manifest_path}" "BA_KIT_RUNTIME")"
    repo="$(read_manifest_value "${manifest_path}" "BA_KIT_SOURCE_REPO")"
    [[ -n "${runtime}" && -n "${repo}" ]] || continue
    printf '%s\t%s\t%s\n' "${runtime}" "${repo}" "${manifest_path}"
  done
}

resolve_registered_repo() {
  if [[ -n "${BA_KIT_SOURCE_REPO:-}" ]]; then
    printf '%s\n' "${BA_KIT_SOURCE_REPO}"
    return 0
  fi

  local installations unique_repos repo_count repo runtime
  installations="$(collect_installations)"

  if [[ -z "${installations}" ]]; then
    fail "No BA-kit installation manifests found under ${MANIFEST_DIR}. Run the installers once before using '${CLI_NAME} status'."
  fi

  unique_repos="$(
    while IFS=$'\t' read -r runtime repo _; do
      [[ -n "${repo:-}" ]] || continue
      printf '%s\n' "${repo}"
    done <<<"${installations}" | sort -u
  )"
  repo_count="$(printf '%s\n' "${unique_repos}" | sed '/^$/d' | wc -l | tr -d ' ')"

  if [[ "${repo_count}" -ne 1 ]]; then
    printf 'Multiple BA-kit source repositories are registered. Resolve this manually before running status:\n' >&2
    print_installations "${installations}"
    exit 1
  fi

  printf '%s\n' "$(printf '%s\n' "${unique_repos}" | sed '/^$/d' | head -n 1)"
}

stat_mtime_epoch() {
  local path="$1"
  if stat -f '%m' "${path}" >/dev/null 2>&1; then
    stat -f '%m' "${path}"
  else
    stat -c '%Y' "${path}"
  fi
}

stat_mtime_pretty() {
  local path="$1"
  if stat -f '%Sm' -t '%Y-%m-%d %H:%M' "${path}" >/dev/null 2>&1; then
    stat -f '%Sm' -t '%Y-%m-%d %H:%M' "${path}"
  else
    date -d "@$(stat -c '%Y' "${path}")" '+%Y-%m-%d %H:%M'
  fi
}

read_md_field() {
  local path="$1"
  local field="$2"

  awk -v target_field="${field}" '
    BEGIN {
      list_target = "- " target_field ": "
      bold_target = "**" target_field ":** "
    }
    index($0, list_target) == 1 {
      print substr($0, length(list_target) + 1)
      exit
    }
    index($0, bold_target) == 1 {
      print substr($0, length(bold_target) + 1)
      exit
    }
  ' "${path}"
}

doctor_ok() {
  printf -- "- [ok] %s\n" "$1"
}

doctor_warn() {
  printf -- "- [warn] %s\n" "$1"
}

doctor_fail() {
  printf -- "- [fail] %s\n" "$1"
}

command_path() {
  local name="$1"
  command -v "${name}" 2>/dev/null || true
}

scan_file_for_token() {
  local path="$1"
  local pattern="$2"
  [[ -f "${path}" ]] || return 1
  rg -qi -- "${pattern}" "${path}"
}

sanitize_cache_key() {
  printf '%s' "$1" | sed 's/[^A-Za-z0-9._-]/_/g'
}

update_cache_path() {
  local repo="$1"
  local upstream_ref="$2"
  mkdir -p "${UPDATE_CACHE_DIR}"
  printf '%s/%s.env\n' "${UPDATE_CACHE_DIR}" "$(sanitize_cache_key "${repo}__${upstream_ref}")"
}

write_update_cache() {
  local path="$1"
  local repo="$2"
  local upstream_ref="$3"
  local local_head="$4"
  local remote_head="$5"
  local status="$6"
  local checked_at="$7"

  cat > "${path}" <<EOF
repo=${repo}
upstream_ref=${upstream_ref}
local_head=${local_head}
remote_head=${remote_head}
status=${status}
checked_at=${checked_at}
EOF
}

resolve_update_status() {
  local repo="$1"
  local local_head upstream_ref remote_name remote_branch cache_path
  local cached_checked_at cached_local_head cached_status cached_remote_head now age remote_head

  git -C "${repo}" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  upstream_ref="$(git -C "${repo}" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
  [[ -n "${upstream_ref}" ]] || return 1

  local_head="$(git -C "${repo}" rev-parse HEAD 2>/dev/null || true)"
  [[ -n "${local_head}" ]] || return 1

  cache_path="$(update_cache_path "${repo}" "${upstream_ref}")"
  now="$(date +%s)"
  if [[ -f "${cache_path}" ]]; then
    cached_checked_at="$(read_manifest_value "${cache_path}" "checked_at")"
    cached_local_head="$(read_manifest_value "${cache_path}" "local_head")"
    cached_status="$(read_manifest_value "${cache_path}" "status")"
    cached_remote_head="$(read_manifest_value "${cache_path}" "remote_head")"
    if [[ "${cached_checked_at}" =~ ^[0-9]+$ ]] && [[ "${cached_local_head}" == "${local_head}" ]]; then
      age="$((now - cached_checked_at))"
      if [[ "${age}" -lt "${UPDATE_CHECK_TTL_SECONDS}" ]]; then
        printf '%s\t%s\t%s\t%s\n' "${cached_status}" "${local_head}" "${cached_remote_head}" "${upstream_ref}"
        return 0
      fi
    fi
  fi

  remote_name="${upstream_ref%%/*}"
  remote_branch="${upstream_ref#*/}"
  remote_head="$(git -C "${repo}" ls-remote "${remote_name}" "refs/heads/${remote_branch}" 2>/dev/null | awk 'NR==1 {print $1}')"
  [[ -n "${remote_head}" ]] || return 1

  if [[ "${remote_head}" == "${local_head}" ]]; then
    write_update_cache "${cache_path}" "${repo}" "${upstream_ref}" "${local_head}" "${remote_head}" "up_to_date" "${now}"
    printf 'up_to_date\t%s\t%s\t%s\n' "${local_head}" "${remote_head}" "${upstream_ref}"
    return 0
  fi

  if git -C "${repo}" merge-base --is-ancestor "${local_head}" "${remote_head}" >/dev/null 2>&1; then
    write_update_cache "${cache_path}" "${repo}" "${upstream_ref}" "${local_head}" "${remote_head}" "update_available" "${now}"
    printf 'update_available\t%s\t%s\t%s\n' "${local_head}" "${remote_head}" "${upstream_ref}"
    return 0
  fi

  write_update_cache "${cache_path}" "${repo}" "${upstream_ref}" "${local_head}" "${remote_head}" "diverged" "${now}"
  printf 'diverged\t%s\t%s\t%s\n' "${local_head}" "${remote_head}" "${upstream_ref}"
}

print_update_notice_if_available() {
  local repo="$1"
  local result status local_head remote_head upstream_ref

  result="$(resolve_update_status "${repo}" 2>/dev/null || true)"
  [[ -n "${result}" ]] || return 0

  IFS=$'\t' read -r status local_head remote_head upstream_ref <<<"${result}"
  if [[ "${status}" == "update_available" ]]; then
    printf 'Update available for BA-kit:\n'
    printf '  local  %s\n' "${local_head:0:7}"
    printf '  remote %s (%s)\n' "${remote_head:0:7}" "${upstream_ref}"
    printf '  run    ba-kit update\n\n'
  fi
}

contract_query() {
  local repo="$1"
  local query="$2"

  python3 - "${repo}/core/contract.yaml" "${query}" <<'PY'
import json
import sys

contract_path, query = sys.argv[1], sys.argv[2]
with open(contract_path, "r", encoding="utf-8") as fh:
    data = json.load(fh)

value = data
for part in query.split("."):
    value = value[part]

if isinstance(value, list):
    print("\n".join(str(item) for item in value))
elif isinstance(value, dict):
    print(json.dumps(value))
else:
    print(value)
PY
}

render_contract_path() {
  local repo="$1"
  local key="$2"
  local slug="${3:-}"
  local date_token="${4:-}"
  local module_slug="${5:-}"
  local group="${6:-}"
  local artifact_name="${7:-}"
  local screen_id="${8:-}"
  local source_hash="${9:-}"
  local template

  template="$(contract_query "${repo}" "paths.${key}")"
  template="${template//\{slug\}/${slug}}"
  template="${template//\{date\}/${date_token}}"
  template="${template//\{module_slug\}/${module_slug}}"
  template="${template//\{group\}/${group}}"
  template="${template//\{artifact_name\}/${artifact_name}}"
  template="${template//\{screen_id\}/${screen_id}}"
  template="${template//\{source_hash\}/${source_hash}}"
  printf '%s\n' "${template}"
}

project_root_path() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  render_contract_path "${repo}" "project_root" "${slug}" "${date_token}"
}

list_project_dirs() {
  local repo="$1"
  local path base

  [[ -d "${repo}/plans" ]] || return 0
  while IFS= read -r -d '' path; do
    base="$(basename "${path}")"
    [[ "${base}" == "reports" || "${base}" == "_source-cache" ]] && continue
    if [[ "${base}" =~ ^(.+)-([0-9]{6}-[0-9]{4})$ ]]; then
      printf '%s\t%s\t%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${path}"
    fi
  done < <(find "${repo}/plans" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
}

collect_candidate_slugs() {
  local repo="$1"
  list_project_dirs "${repo}" | cut -f1 | sed '/^$/d' | sort -u
}

collect_candidate_dates() {
  local repo="$1"
  local slug="$2"
  list_project_dirs "${repo}" | awk -F'\t' -v target="${slug}" '$1 == target {print $2}' | sed '/^$/d' | sort -u
}

collect_modules() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  local root path

  root="$(project_root_path "${repo}" "${slug}" "${date_token}")"
  [[ -d "${repo}/${root}/03_modules" ]] || return 0

  while IFS= read -r -d '' path; do
    basename "${path}"
  done < <(find "${repo}/${root}/03_modules" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
}

resolve_module_name() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  local module="${4:-}"
  local modules module_count

  if [[ -n "${module}" ]]; then
    printf '%s\n' "${module}"
    return 0
  fi

  modules="$(collect_modules "${repo}" "${slug}" "${date_token}")"
  module_count="$(printf '%s\n' "${modules}" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "${module_count}" -eq 1 ]]; then
    printf '%s\n' "$(printf '%s\n' "${modules}" | sed '/^$/d' | head -n 1)"
  fi
}

require_unique_slug() {
  local repo="$1"
  local slug="$2"
  local slugs slug_count

  if [[ -n "${slug}" ]]; then
    printf '%s\n' "${slug}"
    return 0
  fi

  slugs="$(collect_candidate_slugs "${repo}")"
  slug_count="$(printf '%s\n' "${slugs}" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "${slug_count}" -eq 0 ]]; then
    fail "No BA-kit modular project roots found under ${repo}/plans"
  fi
  if [[ "${slug_count}" -gt 1 ]]; then
    printf 'Multiple slugs found. Rerun with --slug. Candidates:\n%s\n' "${slugs}" >&2
    exit 1
  fi
  printf '%s\n' "$(printf '%s\n' "${slugs}" | sed '/^$/d' | head -n 1)"
}

require_unique_date() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  local dates date_count

  if [[ -n "${date_token}" ]]; then
    printf '%s\n' "${date_token}"
    return 0
  fi

  dates="$(collect_candidate_dates "${repo}" "${slug}")"
  date_count="$(printf '%s\n' "${dates}" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "${date_count}" -eq 0 ]]; then
    fail "No dated artifact set found for slug '${slug}' under ${repo}/plans"
  fi
  if [[ "${date_count}" -gt 1 ]]; then
    printf 'Multiple dated sets found for slug %s. Rerun with --date. Candidates:\n%s\n' "${slug}" "${dates}" >&2
    exit 1
  fi
  printf '%s\n' "$(printf '%s\n' "${dates}" | sed '/^$/d' | head -n 1)"
}

module_root_path() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  local module_slug="$4"
  render_contract_path "${repo}" "module_root" "${slug}" "${date_token}" "${module_slug}"
}

design_root_path() {
  local repo="$1"
  local slug="$2"
  render_contract_path "${repo}" "design_root" "${slug}"
}

print_path_if_exists() {
  local path="$1"
  [[ -e "${path}" ]] && printf '%s\n' "${path}"
}

command_requires_module() {
  local repo="$1"
  local command="$2"
  [[ "$(contract_query "${repo}" "commands.${command}.module_required")" == "True" || "$(contract_query "${repo}" "commands.${command}.module_required")" == "true" ]]
}

command_requirements() {
  local repo="$1"
  local command="$2"
  contract_query "${repo}" "commands.${command}.requires"
}

print_artifact_status_line() {
  local path="$1"
  local label="$2"

  if [[ -f "${path}" ]]; then
    printf -- "- [x] %s — %s\n" "${label}" "$(stat_mtime_pretty "${path}")"
  else
    printf -- "- [ ] %s — missing\n" "${label}"
  fi
}

print_wireframe_status_line() {
  local path="$1"

  if [[ ! -f "${path}" ]]; then
    printf -- "- [!] wireframe handoff — missing\n"
    return
  fi

  local state
  state="$(read_md_field "${path}" "State")"
  [[ -n "${state}" ]] || state="unknown"
  printf -- "- [!] wireframe handoff — %s — %s\n" "${state}" "$(stat_mtime_pretty "${path}")"
}

print_json_state_line() {
  local path="$1"
  local label="$2"

  if [[ -f "${path}" ]]; then
    printf -- "- [x] %s — %s\n" "${label}" "$(stat_mtime_pretty "${path}")"
  else
    printf -- "- [ ] %s — missing\n" "${label}"
  fi
}

print_index_table_section() {
  local index_path="$1"
  local heading="$2"

  awk -v heading="${heading}" '
    $0 == heading {
      in_section = 1
      next
    }
    in_section && /^## / {
      exit
    }
    in_section && /^\|/ && $0 !~ /^\|[[:space:]-]+\|/ {
      if (!seen_table) {
        seen_table = 1
        next
      }
      if ($0 ~ /\[[^]]+\]/) {
        next
      }
      print "  " $0
    }
  ' "${index_path}"
}

print_memory_status() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  local compact_path memory_root index_path packet_root packet_count
  local activation_level activation_status activation_refresh activation_signals last_runtime last_refresh
  local owner_rows health_rows fileback_rows packet_rows

  compact_path="${repo}/$(render_contract_path "${repo}" "project_memory" "${slug}" "${date_token}")"
  memory_root="${repo}/$(render_contract_path "${repo}" "memory_root" "${slug}" "${date_token}")"
  index_path="${repo}/$(render_contract_path "${repo}" "memory_index" "${slug}" "${date_token}")"
  packet_root="${repo}/$(render_contract_path "${repo}" "packet_root" "${slug}" "${date_token}")"

  printf '\n[Memory]\n'

  if [[ -f "${compact_path}" ]]; then
    printf -- "- [x] 02_backbone/project-memory.md — %s\n" "$(stat_mtime_pretty "${compact_path}")"
    activation_level="$(read_md_field "${compact_path}" "Activation Level")"
    last_runtime="$(read_md_field "${compact_path}" "Host runtime gần nhất (Last Runtime)")"
    last_refresh="$(read_md_field "${compact_path}" "Nguồn làm mới gần nhất (Last Refresh Source)")"
    [[ -n "${activation_level}" ]] && printf -- "  activation: %s\n" "${activation_level}"
    [[ -n "${last_runtime}" ]] && printf -- "  last runtime: %s\n" "${last_runtime}"
    [[ -n "${last_refresh}" ]] && printf -- "  last refresh source: %s\n" "${last_refresh}"
  else
    printf -- "- [ ] 02_backbone/project-memory.md — missing\n"
  fi

  if [[ -d "${memory_root}" ]]; then
    if [[ -f "${index_path}" ]]; then
      printf -- "- [x] 02_backbone/project-memory/index.md — %s\n" "$(stat_mtime_pretty "${index_path}")"
      activation_level="$(read_md_field "${index_path}" "Activation Level")"
      activation_status="$(read_md_field "${index_path}" "Activation Status")"
      activation_refresh="$(read_md_field "${index_path}" "Last Activation Refresh")"
      activation_signals="$(read_md_field "${index_path}" "Computed Signals")"
      [[ -n "${activation_level}" ]] && printf -- "  activation: %s\n" "${activation_level}"
      [[ -n "${activation_status}" ]] && printf -- "  activation status: %s\n" "${activation_status}"
      [[ -n "${activation_refresh}" ]] && printf -- "  activation refreshed: %s\n" "${activation_refresh}"
      [[ -n "${activation_signals}" ]] && printf -- "  signals: %s\n" "${activation_signals}"

      owner_rows="$(print_index_table_section "${index_path}" "## Owner Metadata")"
      [[ -n "${owner_rows}" ]] && printf -- "  owner metadata:\n%s\n" "${owner_rows}"
      health_rows="$(print_index_table_section "${index_path}" "## Shard Health")"
      [[ -n "${health_rows}" ]] && printf -- "  shard freshness:\n%s\n" "${health_rows}"
      fileback_rows="$(print_index_table_section "${index_path}" "## File-Back Promotions")"
      [[ -n "${fileback_rows}" ]] && printf -- "  file-back promotions:\n%s\n" "${fileback_rows}"
      packet_rows="$(print_index_table_section "${index_path}" "## Packet Registry")"
      [[ -n "${packet_rows}" ]] && printf -- "  packet registry:\n%s\n" "${packet_rows}"
    else
      printf -- "- [!] 02_backbone/project-memory/index.md — missing; compact fallback required\n"
    fi
  else
    printf -- "- [ ] 02_backbone/project-memory/ — not initialized\n"
  fi

  if [[ -d "${packet_root}" ]]; then
    packet_count="$(find "${packet_root}" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
    printf -- "- [x] delegation/packets — %s packet(s)\n" "${packet_count}"
  else
    printf -- "- [ ] delegation/packets — not initialized\n"
  fi
}

delegation_icon() {
  local display_status="$1"

  case "${display_status}" in
    "likely stalled")
      printf '!'
      ;;
    running|queued)
      printf '~'
      ;;
    *)
      printf 'x'
      ;;
  esac
}

print_delegation_status() {
  local repo="$1"
  local slug="$2"
  local date_token="$3"
  local dir now found path base slice_status threshold age_minutes display_status last_heartbeat note

  dir="${repo}/$(render_contract_path "${repo}" "delegation_root" "${slug}" "${date_token}")"
  [[ -d "${dir}" ]] || return 0

  now="$(date +%s)"
  found=0
  shopt -s nullglob
  for path in "${dir}"/*.md; do
    [[ -f "${path}" ]] || continue
    if [[ "${found}" -eq 0 ]]; then
      printf '\nDelegated slices:\n\n'
      found=1
    fi
    base="$(basename "${path}" .md)"
    slice_status="$(read_md_field "${path}" "Status")"
    threshold="$(read_md_field "${path}" "Stall Threshold Minutes")"
    last_heartbeat="$(read_md_field "${path}" "Last Heartbeat At")"
    note="$(read_md_field "${path}" "Latest Milestone Or Blocker")"
    [[ -n "${slice_status}" ]] || slice_status="unknown"
    [[ "${threshold}" =~ ^[0-9]+$ ]] || threshold="$(contract_query "${repo}" "states.stall_after_minutes")"
    age_minutes="$(( (now - $(stat_mtime_epoch "${path}")) / 60 ))"
    display_status="${slice_status}"
    if [[ ( "${slice_status}" == "running" || "${slice_status}" == "queued" ) && "${age_minutes}" -gt "${threshold}" ]]; then
      display_status="likely stalled"
    fi

    if [[ -n "${last_heartbeat}" ]]; then
      printf -- "- [%s] %s — %s — last heartbeat %s" \
        "$(delegation_icon "${display_status}")" \
        "${base}" "${display_status}" "${last_heartbeat}"
    else
      printf -- "- [%s] %s — %s — tracker updated %s" \
        "$(delegation_icon "${display_status}")" \
        "${base}" "${display_status}" "$(stat_mtime_pretty "${path}")"
    fi
    if [[ "${display_status}" == "likely stalled" ]]; then
      printf ' (>%sm threshold)' "${threshold}"
    fi
    if [[ -n "${note}" ]]; then
      printf ' — %s' "${note}"
    fi
    printf '\n'
  done
  shopt -u nullglob
}

print_installations() {
  local installations="$1"
  local line runtime repo manifest_path

  while IFS=$'\t' read -r runtime repo manifest_path; do
    [[ -n "${runtime:-}" ]] || continue
    printf '  - runtime=%s repo=%s manifest=%s\n' "${runtime}" "${repo}" "${manifest_path}" >&2
  done <<<"${installations}"
}

doctor_command_check() {
  local label="$1"
  local command_name="$2"
  local required="$3"
  local resolved

  resolved="$(command_path "${command_name}")"
  if [[ -n "${resolved}" ]]; then
    doctor_ok "${label} available at ${resolved}"
    return 0
  fi

  if [[ "${required}" == "required" ]]; then
    doctor_fail "${label} not found on PATH"
    return 1
  fi

  doctor_warn "${label} not found on PATH"
  return 0
}

doctor_file_check() {
  local label="$1"
  local path="$2"
  local required="$3"

  if [[ -e "${path}" ]]; then
    doctor_ok "${label} present at ${path}"
    return 0
  fi

  if [[ "${required}" == "required" ]]; then
    doctor_fail "${label} missing at ${path}"
    return 1
  fi

  doctor_warn "${label} missing at ${path}"
  return 0
}

doctor_mcp_check() {
  local label="$1"
  local token="$2"
  local codex_config="${HOME}/.codex/config.toml"
  local claude_settings="${HOME}/.claude/settings.json"
  local claude_config="${HOME}/.claude.json"
  local gemini_global="${HOME}/.gemini/settings.json"
  local gemini_project

  if scan_file_for_token "${codex_config}" "${token}"; then
    doctor_ok "${label} detected in ${codex_config}"
    return 0
  fi
  if scan_file_for_token "${claude_settings}" "${token}"; then
    doctor_ok "${label} detected in ${claude_settings}"
    return 0
  fi
  if scan_file_for_token "${claude_config}" "${token}"; then
    doctor_ok "${label} detected in ${claude_config}"
    return 0
  fi
  if scan_file_for_token "${gemini_global}" "${token}"; then
    doctor_ok "${label} detected in ${gemini_global}"
    return 0
  fi
  # Check project-level .gemini/settings.json if we have a resolved repo
  if [[ -n "${BA_KIT_DOCTOR_REPO:-}" ]]; then
    gemini_project="${BA_KIT_DOCTOR_REPO}/.gemini/settings.json"
    if scan_file_for_token "${gemini_project}" "${token}"; then
      doctor_ok "${label} detected in ${gemini_project}"
      return 0
    fi
  fi

  doctor_warn "${label} not detected in local Codex/Claude/Antigravity config files"
  return 1
}

git_path_exists() {
  local repo="$1"
  local git_path_name="$2"
  local resolved

  resolved="$(git -C "${repo}" rev-parse --git-path "${git_path_name}")"
  [[ -e "${resolved}" ]]
}

ensure_repo_ready() {
  local repo="$1"

  git -C "${repo}" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "Source path is not a git repository: ${repo}"

  if git_path_exists "${repo}" "MERGE_HEAD"; then
    fail "Repository has an unfinished merge: ${repo}"
  fi
  if git_path_exists "${repo}" "CHERRY_PICK_HEAD"; then
    fail "Repository has an unfinished cherry-pick: ${repo}"
  fi
  if git_path_exists "${repo}" "REVERT_HEAD"; then
    fail "Repository has an unfinished revert: ${repo}"
  fi
  if git_path_exists "${repo}" "rebase-apply"; then
    fail "Repository has an unfinished rebase: ${repo}"
  fi
  if git_path_exists "${repo}" "rebase-merge"; then
    fail "Repository has an unfinished rebase: ${repo}"
  fi

  if [[ -n "$(git -C "${repo}" status --short)" ]]; then
    printf 'Repository has local changes and cannot be updated safely:\n' >&2
    git -C "${repo}" status --short >&2
    exit 1
  fi

  if ! git -C "${repo}" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
    fail "Current branch has no upstream configured in ${repo}"
  fi
}

run_installer() {
  local repo="$1"
  local runtime="$2"

  case "${runtime}" in
    claude)
      [[ -x "${repo}/install.sh" ]] || fail "Claude installer missing: ${repo}/install.sh"
      (cd "${repo}" && ./install.sh)
      ;;
    codex)
      [[ -x "${repo}/scripts/install-codex-ba-kit.sh" ]] || fail "Codex installer missing: ${repo}/scripts/install-codex-ba-kit.sh"
      (cd "${repo}" && ./scripts/install-codex-ba-kit.sh)
      ;;
    antigravity)
      [[ -f "${repo}/scripts/install-antigravity-ba-kit.sh" ]] || fail "Antigravity installer missing: ${repo}/scripts/install-antigravity-ba-kit.sh"
      (cd "${repo}" && bash ./scripts/install-antigravity-ba-kit.sh)
      ;;
    *)
      fail "Unsupported runtime in installation manifest: ${runtime}"
      ;;
  esac
}

update_command() {
  local installations unique_repos repo_count repo before after branch upstream runtime
  installations="$(collect_installations)"

  if [[ -z "${installations}" ]]; then
    fail "No BA-kit installation manifests found under ${MANIFEST_DIR}. Run the installers once before using 'ba-kit update'."
  fi

  unique_repos="$(
    while IFS=$'\t' read -r runtime repo _; do
      [[ -n "${repo:-}" ]] || continue
      printf '%s\n' "${repo}"
    done <<<"${installations}" | sort -u
  )"
  repo_count="$(printf '%s\n' "${unique_repos}" | sed '/^$/d' | wc -l | tr -d ' ')"

  if [[ "${repo_count}" -ne 1 ]]; then
    printf 'Multiple BA-kit source repositories are registered. Resolve this manually before updating:\n' >&2
    print_installations "${installations}"
    exit 1
  fi

  repo="$(printf '%s\n' "${unique_repos}" | sed '/^$/d' | head -n 1)"
  ensure_repo_ready "${repo}"

  branch="$(git -C "${repo}" rev-parse --abbrev-ref HEAD)"
  upstream="$(git -C "${repo}" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}')"
  before="$(git -C "${repo}" rev-parse --short HEAD)"

  printf 'Updating BA-kit from %s\n' "${repo}"
  printf 'Branch: %s | Upstream: %s | Before: %s\n' "${branch}" "${upstream}" "${before}"
  git -C "${repo}" pull --ff-only
  after="$(git -C "${repo}" rev-parse --short HEAD)"

  printf 'Reinstalling runtimes:\n'
  while IFS=$'\t' read -r runtime manifest_repo _; do
    [[ -n "${runtime:-}" ]] || continue
    [[ "${manifest_repo}" == "${repo}" ]] || continue
    printf '  - %s\n' "${runtime}"
    run_installer "${repo}" "${runtime}"
  done <<<"${installations}"

  printf 'Update complete. Before: %s | After: %s\n' "${before}" "${after}"
}

doctor_command() {
  [[ "$#" -eq 0 ]] || fail "Unsupported arguments for 'doctor'"

  local failures=0
  local warnings=0
  local installations installation_count unique_repos repo_count repo runtime manifest_path source_state
  local local_bin_cli="${HOME}/.local/bin/ba-kit"
  local repo_resolved=0
  local script_repo source_check_repo
  local update_result update_status update_local_head update_remote_head update_upstream_ref

  printf 'BA-kit Doctor\n\n'

  doctor_command_check "bash" "bash" "required" || failures=$((failures + 1))
  doctor_command_check "python3" "python3" "required" || failures=$((failures + 1))
  doctor_command_check "rg" "rg" "required" || failures=$((failures + 1))
  if doctor_command_check "node" "node" "optional"; then :; else failures=$((failures + 1)); fi
  printf '\n'

  doctor_file_check "shared CLI" "${local_bin_cli}" "optional" || failures=$((failures + 1))
  doctor_file_check "installation manifest dir" "${MANIFEST_DIR}" "optional" || failures=$((failures + 1))
  printf '\n'

  installations="$(collect_installations)"
  installation_count="$(printf '%s\n' "${installations}" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "${installation_count}" -eq 0 ]]; then
    doctor_warn "no BA-kit installation manifests found under ${MANIFEST_DIR}"
    warnings=$((warnings + 1))
  else
    doctor_ok "${installation_count} installation manifest(s) found"
    while IFS=$'\t' read -r runtime repo manifest_path; do
      [[ -n "${runtime:-}" ]] || continue
      if [[ -d "${repo}" ]]; then
        doctor_ok "runtime=${runtime} registered to repo ${repo} via ${manifest_path}"
      else
        doctor_fail "runtime=${runtime} manifest points to missing repo ${repo}"
        failures=$((failures + 1))
      fi
    done <<<"${installations}"
  fi

  if [[ -n "${installations}" ]]; then
    unique_repos="$(
      while IFS=$'\t' read -r runtime repo _; do
        [[ -n "${repo:-}" ]] || continue
        printf '%s\n' "${repo}"
      done <<<"${installations}" | sed '/^$/d' | sort -u
    )"
    repo_count="$(printf '%s\n' "${unique_repos}" | sed '/^$/d' | wc -l | tr -d ' ')"
    if [[ "${repo_count}" -eq 1 ]]; then
      repo="$(printf '%s\n' "${unique_repos}" | sed '/^$/d' | head -n 1)"
      repo_resolved=1
      BA_KIT_DOCTOR_REPO="${repo}"
      if git -C "${repo}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        doctor_ok "registered source repo is a git worktree: ${repo}"
        source_state="$(git -C "${repo}" status --short || true)"
        if [[ -n "${source_state}" ]]; then
          doctor_warn "registered source repo has local changes"
          warnings=$((warnings + 1))
        else
          doctor_ok "registered source repo is clean"
        fi
      else
        doctor_fail "registered source repo is not a git worktree: ${repo}"
        failures=$((failures + 1))
      fi
    elif [[ "${repo_count}" -gt 1 ]]; then
      doctor_fail "multiple registered BA-kit source repos detected"
      failures=$((failures + 1))
      print_installations "${installations}"
    fi
  fi

  script_repo="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  source_check_repo=""
  if [[ "${repo_resolved}" -eq 1 ]]; then
    source_check_repo="${repo}"
  elif [[ -f "${script_repo}/core/contract.yaml" ]]; then
    source_check_repo="${script_repo}"
    doctor_warn "no registered source repo resolved; checking source files relative to running script"
    warnings=$((warnings + 1))
  else
    doctor_warn "source repo not resolved; skipping installer and renderer file checks"
    warnings=$((warnings + 1))
  fi

  if [[ -n "${source_check_repo}" ]]; then
    doctor_file_check "Claude installer" "${source_check_repo}/install.sh" "required" || failures=$((failures + 1))
    doctor_file_check "Codex installer" "${source_check_repo}/scripts/install-codex-ba-kit.sh" "required" || failures=$((failures + 1))
    doctor_file_check "Antigravity installer" "${source_check_repo}/scripts/install-antigravity-ba-kit.sh" "required" || failures=$((failures + 1))
    doctor_file_check "HTML renderer" "${source_check_repo}/scripts/md-to-html.py" "required" || failures=$((failures + 1))
  fi

  if [[ "${repo_resolved}" -eq 1 && "${BA_KIT_SKIP_UPDATE_CHECK:-0}" == "1" ]]; then
    doctor_warn "BA-kit update status check skipped by BA_KIT_SKIP_UPDATE_CHECK"
    warnings=$((warnings + 1))
  elif [[ "${repo_resolved}" -eq 1 ]]; then
    update_result="$(resolve_update_status "${repo}" 2>/dev/null || true)"
    if [[ -n "${update_result}" ]]; then
      IFS=$'\t' read -r update_status update_local_head update_remote_head update_upstream_ref <<<"${update_result}"
      case "${update_status}" in
        up_to_date)
          doctor_ok "BA-kit is up to date with ${update_upstream_ref} (${update_local_head:0:7})"
          ;;
        update_available)
          doctor_warn "BA-kit update available: ${update_local_head:0:7} -> ${update_remote_head:0:7} (${update_upstream_ref})"
          warnings=$((warnings + 1))
          ;;
        diverged)
          doctor_warn "BA-kit local branch diverged from ${update_upstream_ref}: local ${update_local_head:0:7}, remote ${update_remote_head:0:7}"
          warnings=$((warnings + 1))
          ;;
      esac
    else
      doctor_warn "could not verify BA-kit update status from upstream"
      warnings=$((warnings + 1))
    fi
  fi
  printf '\n'

  doctor_mcp_check "Notion MCP" "notion" || warnings=$((warnings + 1))
  printf '\n'

  if [[ -d "${HOME}/.codex" ]]; then
    doctor_ok "Codex home detected at ${HOME}/.codex"
  else
    doctor_warn "Codex home not detected at ${HOME}/.codex"
    warnings=$((warnings + 1))
  fi
  if [[ -d "${HOME}/.claude" ]]; then
    doctor_ok "Claude home detected at ${HOME}/.claude"
  else
    doctor_warn "Claude home not detected at ${HOME}/.claude"
    warnings=$((warnings + 1))
  fi
  if [[ -d "${HOME}/.gemini/antigravity" ]]; then
    doctor_ok "Antigravity home detected at ${HOME}/.gemini/antigravity"
  else
    doctor_warn "Antigravity home not detected at ${HOME}/.gemini/antigravity"
    warnings=$((warnings + 1))
  fi
  printf '\n'

  if [[ "${repo_resolved}" -eq 1 && -d "${repo}/skills/ba-notion" ]]; then
    doctor_ok "ba-notion skill source present in registered repo"
  elif [[ "${repo_resolved}" -eq 1 ]]; then
    doctor_warn "ba-notion skill source not found in registered repo"
    warnings=$((warnings + 1))
  fi

  if [[ -d "${HOME}/.codex/skills/ba-notion" || -d "${HOME}/.claude/skills/ba-notion" ]]; then
    doctor_ok "ba-notion installed in at least one runtime"
  else
    doctor_warn "ba-notion not installed into ~/.codex/skills or ~/.claude/skills"
    warnings=$((warnings + 1))
  fi
  if [[ -d "${HOME}/.gemini/antigravity/knowledge/ba-kit-workflow" ]]; then
    doctor_ok "BA-kit workflow KI installed for Antigravity"
  else
    doctor_warn "BA-kit workflow KI not installed for Antigravity (run scripts/install-antigravity-ba-kit.sh)"
    warnings=$((warnings + 1))
  fi

  printf '\nSummary: %s failure(s), %s warning(s)\n' "${failures}" "${warnings}"
  if [[ "${failures}" -gt 0 ]]; then
    exit 1
  fi
}

status_command() {
  local slug="" date_token="" module="" repo slugs slug_count dates date_count root modules

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --date)
        [[ "$#" -ge 2 ]] || fail "Missing value for --date"
        date_token="$2"
        shift 2
        ;;
      --module)
        [[ "$#" -ge 2 ]] || fail "Missing value for --module"
        module="$2"
        shift 2
        ;;
      *)
        fail "Unsupported argument for 'status': $1"
        ;;
    esac
  done

  repo="$(resolve_registered_repo)"
  print_update_notice_if_available "${repo}"

  slug="$(require_unique_slug "${repo}" "${slug}")"
  date_token="$(require_unique_date "${repo}" "${slug}" "${date_token}")"

  printf 'Project: %s\n' "${slug}"
  printf 'Date set: %s\n\n' "${date_token}"

  root="$(project_root_path "${repo}" "${slug}" "${date_token}")"
  printf '[Source]\n'
  print_json_state_line "${repo}/$(render_contract_path "${repo}" "source_manifest" "${slug}" "${date_token}")" "00_source/manifest.json"
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "source_summary" "${slug}" "${date_token}")" "00_source/summary.md"

  printf '\n[Core]\n'
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "intake" "${slug}" "${date_token}")" "01_intake/intake.md"
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "plan" "${slug}" "${date_token}")" "01_intake/plan.md"
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "backbone" "${slug}" "${date_token}")" "02_backbone/backbone.md"
  print_memory_status "${repo}" "${slug}" "${date_token}"

  modules="${module}"
  if [[ -z "${modules}" ]]; then
    modules="$(collect_modules "${repo}" "${slug}" "${date_token}")"
  fi
  if [[ -n "${modules}" ]]; then
    while IFS= read -r module_name; do
      [[ -n "${module_name}" ]] || continue
      printf '\n[Module: %s]\n' "${module_name}"
      print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "frd" "${slug}" "${date_token}" "${module_name}")" "03_modules/${module_name}/frd.md"
      print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "stories" "${slug}" "${date_token}" "${module_name}")" "03_modules/${module_name}/user-stories.md"
      print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "srs" "${slug}" "${date_token}" "${module_name}")" "03_modules/${module_name}/srs.md"
      print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "wireframe_input" "${slug}" "${date_token}" "${module_name}")" "03_modules/${module_name}/wireframe-input.md"
      print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "wireframe_map" "${slug}" "${date_token}" "${module_name}")" "03_modules/${module_name}/wireframe-map.md"
      print_wireframe_status_line "${repo}/$(render_contract_path "${repo}" "wireframe_state" "${slug}" "${date_token}" "${module_name}")"
    done <<<"${modules}"
  fi

  printf '\n[Compiled]\n'
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "compiled_frd" "${slug}" "${date_token}")" "04_compiled/compiled-frd.html"
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "compiled_srs" "${slug}" "${date_token}")" "04_compiled/compiled-srs.html"

  printf '\n[Designs]\n'
  print_artifact_status_line "${repo}/$(render_contract_path "${repo}" "design_doc" "${slug}")" "designs/${slug}/DESIGN.md"
  print_delegation_status "${repo}" "${slug}" "${date_token}"
}

resolve_command() {
  local slug="" date_token="" module="" repo root resolved_module module_root

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --date)
        [[ "$#" -ge 2 ]] || fail "Missing value for --date"
        date_token="$2"
        shift 2
        ;;
      --module)
        [[ "$#" -ge 2 ]] || fail "Missing value for --module"
        module="$2"
        shift 2
        ;;
      *)
        fail "Unsupported argument for 'resolve': $1"
        ;;
    esac
  done

  repo="$(resolve_registered_repo)"
  slug="$(require_unique_slug "${repo}" "${slug}")"
  date_token="$(require_unique_date "${repo}" "${slug}" "${date_token}")"

  root="$(project_root_path "${repo}" "${slug}" "${date_token}")"
  resolved_module="$(resolve_module_name "${repo}" "${slug}" "${date_token}" "${module}")"

  printf 'Project: %s\n' "${slug}"
  printf 'Date set: %s\n' "${date_token}"
  printf 'Project root: %s/%s\n' "${repo}" "${root}"
  if [[ -n "${resolved_module}" ]]; then
    module_root="$(module_root_path "${repo}" "${slug}" "${date_token}" "${resolved_module}")"
    printf 'Module: %s\n' "${resolved_module}"
    printf 'Module root: %s/%s\n' "${repo}" "${module_root}"
  fi
}

check_prereq_command() {
  local target_command="${1:-}"
  local slug="" date_token="" module="" repo requires requirement path

  [[ -n "${target_command}" ]] || fail "Usage: ba-kit check-prereq <command> [--slug ... --date ... --module ...]"
  shift || true

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --date)
        [[ "$#" -ge 2 ]] || fail "Missing value for --date"
        date_token="$2"
        shift 2
        ;;
      --module)
        [[ "$#" -ge 2 ]] || fail "Missing value for --module"
        module="$2"
        shift 2
        ;;
      *)
        fail "Unsupported argument for 'check-prereq': $1"
        ;;
    esac
  done

  repo="$(resolve_registered_repo)"
  slug="$(require_unique_slug "${repo}" "${slug}")"
  date_token="$(require_unique_date "${repo}" "${slug}" "${date_token}")"
  if command_requires_module "${repo}" "${target_command}"; then
    module="$(resolve_module_name "${repo}" "${slug}" "${date_token}" "${module}")"
    [[ -n "${module}" ]] || fail "Command '${target_command}' requires --module or a single resolvable module."
  fi

  requires="$(command_requirements "${repo}" "${target_command}")"
  while IFS= read -r requirement; do
    [[ -n "${requirement}" ]] || continue
    path="$(render_contract_path "${repo}" "${requirement}" "${slug}" "${date_token}" "${module}")"
    if [[ ! -f "${repo}/${path}" ]]; then
      printf 'Missing: %s\n' "${repo}/${path}"
      case "${requirement}" in
        intake) printf 'Run first: ba-start intake\n' ;;
        backbone) printf 'Run first: ba-start backbone --slug %s\n' "${slug}" ;;
        stories) printf 'Run first: ba-start stories --slug %s --module %s\n' "${slug}" "${module}" ;;
        wireframe_input) printf 'Run first: ba-start srs --slug %s --module %s\n' "${slug}" "${module}" ;;
      esac
      exit 1
    fi
  done <<<"${requires}"

  printf 'OK: %s prerequisites satisfied\n' "${target_command}"
}

next_command() {
  local slug="" date_token="" module="" repo story_path srs_path wireframe_input_path wireframe_state_path compiled_frd compiled_srs

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --date)
        [[ "$#" -ge 2 ]] || fail "Missing value for --date"
        date_token="$2"
        shift 2
        ;;
      --module)
        [[ "$#" -ge 2 ]] || fail "Missing value for --module"
        module="$2"
        shift 2
        ;;
      *)
        fail "Unsupported argument for 'next': $1"
        ;;
    esac
  done

  repo="$(resolve_registered_repo)"
  slug="$(require_unique_slug "${repo}" "${slug}")"
  date_token="$(require_unique_date "${repo}" "${slug}" "${date_token}")"

  if [[ ! -f "${repo}/$(render_contract_path "${repo}" "intake" "${slug}" "${date_token}")" ]]; then
    printf 'Next command: ba-start intake\n'
    printf 'Reason: intake is missing.\n'
    return 0
  fi
  if [[ ! -f "${repo}/$(render_contract_path "${repo}" "backbone" "${slug}" "${date_token}")" ]]; then
    printf 'Next command: ba-start backbone --slug %s\n' "${slug}"
    printf 'Reason: backbone is missing.\n'
    return 0
  fi

  module="$(resolve_module_name "${repo}" "${slug}" "${date_token}" "${module}")"
  [[ -n "${module}" ]] || fail "Next-step detection needs --module when more than one module exists."

  story_path="${repo}/$(render_contract_path "${repo}" "stories" "${slug}" "${date_token}" "${module}")"
  srs_path="${repo}/$(render_contract_path "${repo}" "srs" "${slug}" "${date_token}" "${module}")"
  wireframe_input_path="${repo}/$(render_contract_path "${repo}" "wireframe_input" "${slug}" "${date_token}" "${module}")"
  wireframe_state_path="${repo}/$(render_contract_path "${repo}" "wireframe_state" "${slug}" "${date_token}" "${module}")"
  compiled_frd="${repo}/$(render_contract_path "${repo}" "compiled_frd" "${slug}" "${date_token}")"
  compiled_srs="${repo}/$(render_contract_path "${repo}" "compiled_srs" "${slug}" "${date_token}")"

  if [[ ! -f "${story_path}" ]]; then
    printf 'Next command: ba-start stories --slug %s --module %s\n' "${slug}" "${module}"
    printf 'Reason: user stories are missing.\n'
    return 0
  fi
  if [[ ! -f "${srs_path}" ]]; then
    printf 'Next command: ba-start srs --slug %s --module %s\n' "${slug}" "${module}"
    printf 'Reason: SRS is missing for the resolved module.\n'
    return 0
  fi
  if [[ -f "${wireframe_input_path}" && ! -f "${wireframe_state_path}" ]]; then
    printf 'Next command: ba-start wireframes --slug %s --module %s\n' "${slug}" "${module}"
    printf 'Reason: wireframe constraint pack exists but wireframe handoff state is missing.\n'
    return 0
  fi
  if [[ ! -f "${compiled_frd}" || ! -f "${compiled_srs}" ]]; then
    printf 'Next command: ba-start package --slug %s\n' "${slug}"
    printf 'Reason: compiled HTML is missing.\n'
    return 0
  fi

  printf 'Next command: ba-start status --slug %s\n' "${slug}"
  printf 'Reason: required artifacts already exist for the resolved module.\n'
}

template_section_command() {
  local template_name="${1:-}"
  local group="${2:-}"
  local repo manifest_path template_path

  [[ -n "${template_name}" && -n "${group}" ]] || fail "Usage: ba-kit template-section <template> <group>"
  repo="$(resolve_registered_repo)"
  manifest_path="${repo}/$(contract_query "${repo}" "templates.manifest")"
  template_path="${repo}/templates/${template_name}"
  [[ -f "${template_path}" ]] || fail "Template not found: ${template_path}"

  python3 - "${manifest_path}" "${template_path}" "${template_name}" "${group}" <<'PY'
import json
import re
import sys
from pathlib import Path

manifest_path, template_path, template_name, group = sys.argv[1:5]
manifest = json.loads(Path(manifest_path).read_text(encoding="utf-8"))
template_info = manifest.get(template_name)
if not template_info:
    raise SystemExit(f"Template '{template_name}' is not indexed in {manifest_path}")
group_info = template_info["groups"].get(group)
if not group_info:
    raise SystemExit(f"Group '{group}' is not defined for {template_name}")

lines = Path(template_path).read_text(encoding="utf-8").splitlines()
heading_re = re.compile(r"^(#{1,6})\s+(.+)$")
headings = []
for idx, line in enumerate(lines):
    match = heading_re.match(line.strip())
    if match:
        headings.append((idx, len(match.group(1)), line.strip()))

def extract_block(target_heading: str) -> list[str]:
    for i, (start_idx, level, heading_text) in enumerate(headings):
        if heading_text == target_heading:
            end_idx = len(lines)
            for next_idx, next_level, _ in headings[i + 1:]:
                if next_level <= level:
                    end_idx = next_idx
                    break
            return lines[start_idx:end_idx]
    raise SystemExit(f"Heading '{target_heading}' not found in {template_path}")

blocks = []
for heading in group_info["headings"]:
    blocks.extend(extract_block(heading))
    blocks.append("")

print("\n".join(blocks).rstrip())
PY
}

source_extract_command() {
  local source_path="${1:-}"
  local slug="" date_token="" chunk_chars="4000" copy_raw=0 promote=0
  local repo cache_root_template cache_root_arg promoted_root=""

  [[ -n "${source_path}" ]] || fail "Usage: ba-kit source-extract <file> [--slug ... --date ... --chunk-chars <n> --copy-raw --promote]"
  shift || true

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --date)
        [[ "$#" -ge 2 ]] || fail "Missing value for --date"
        date_token="$2"
        shift 2
        ;;
      --chunk-chars)
        [[ "$#" -ge 2 ]] || fail "Missing value for --chunk-chars"
        chunk_chars="$2"
        shift 2
        ;;
      --copy-raw)
        copy_raw=1
        shift
        ;;
      --promote)
        promote=1
        shift
        ;;
      *)
        fail "Unsupported argument for 'source-extract': $1"
        ;;
    esac
  done

  [[ "${chunk_chars}" =~ ^[0-9]+$ ]] || fail "--chunk-chars must be an integer"
  repo="$(resolve_registered_repo)"
  cache_root_template="$(contract_query "${repo}" "paths.source_cache_root")"
  cache_root_arg="${repo}/${cache_root_template}"

  if [[ "${promote}" -eq 1 ]]; then
    slug="$(require_unique_slug "${repo}" "${slug}")"
    date_token="$(require_unique_date "${repo}" "${slug}" "${date_token}")"
    promoted_root="${repo}/$(render_contract_path "${repo}" "source_promoted_root" "${slug}" "${date_token}")"
  fi

  local cmd=(python3 "${repo}/scripts/source-extract.py" "${source_path}" --cache-root "${cache_root_arg}" --chunk-chars "${chunk_chars}")
  if [[ "${copy_raw}" -eq 1 ]]; then
    cmd+=(--copy-raw)
  fi
  if [[ -n "${promoted_root}" ]]; then
    cmd+=(--promote-root "${promoted_root}")
  fi
  "${cmd[@]}"
}

design_snapshot_command() {
  local slug="" design_doc="" repo output_path

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --design-doc)
        [[ "$#" -ge 2 ]] || fail "Missing value for --design-doc"
        design_doc="$2"
        shift 2
        ;;
      *)
        fail "Unsupported argument for 'design-snapshot': $1"
        ;;
    esac
  done

  repo="$(resolve_registered_repo)"
  slug="$(require_unique_slug "${repo}" "${slug}")"
  if [[ -z "${design_doc}" ]]; then
    design_doc="${repo}/designs/${slug}/DESIGN.md"
  fi
  output_path="${repo}/designs/${slug}/.design-snapshot.md"
  python3 "${repo}/scripts/design-snapshot.py" --design-doc "${design_doc}" --output "${output_path}" --slug "${slug}"
}

stitch_state_command() {
  local subcommand="${1:-}"
  local slug="" project_id="" screen="" status_value="" screen_ref="" artifact="" prompt=""
  local repo state_path

  [[ -n "${subcommand}" ]] || fail "Usage: ba-kit stitch-state <init|show|upsert> --slug <slug> [options]"
  shift || true

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --slug)
        [[ "$#" -ge 2 ]] || fail "Missing value for --slug"
        slug="$2"
        shift 2
        ;;
      --project-id)
        [[ "$#" -ge 2 ]] || fail "Missing value for --project-id"
        project_id="$2"
        shift 2
        ;;
      --screen)
        [[ "$#" -ge 2 ]] || fail "Missing value for --screen"
        screen="$2"
        shift 2
        ;;
      --status)
        [[ "$#" -ge 2 ]] || fail "Missing value for --status"
        status_value="$2"
        shift 2
        ;;
      --screen-ref)
        [[ "$#" -ge 2 ]] || fail "Missing value for --screen-ref"
        screen_ref="$2"
        shift 2
        ;;
      --artifact)
        [[ "$#" -ge 2 ]] || fail "Missing value for --artifact"
        artifact="$2"
        shift 2
        ;;
      --prompt)
        [[ "$#" -ge 2 ]] || fail "Missing value for --prompt"
        prompt="$2"
        shift 2
        ;;
      *)
        fail "Unsupported argument for 'stitch-state': $1"
        ;;
    esac
  done

  repo="$(resolve_registered_repo)"
  slug="$(require_unique_slug "${repo}" "${slug}")"
  state_path="${repo}/designs/${slug}/stitch-state.json"

  case "${subcommand}" in
    init)
      local cmd=(python3 "${repo}/scripts/stitch-state.py" init --path "${state_path}")
      if [[ -n "${project_id}" ]]; then
        cmd+=(--project-id "${project_id}")
      fi
      "${cmd[@]}"
      ;;
    show)
      [[ -z "${project_id}${screen}${status_value}${screen_ref}${artifact}${prompt}" ]] || fail "'show' does not accept update fields"
      python3 "${repo}/scripts/stitch-state.py" show --path "${state_path}"
      ;;
    upsert)
      [[ -n "${screen}" ]] || fail "'upsert' requires --screen"
      [[ -n "${status_value}" ]] || fail "'upsert' requires --status"
      local cmd=(python3 "${repo}/scripts/stitch-state.py" upsert --path "${state_path}" --screen "${screen}" --status "${status_value}")
      if [[ -n "${project_id}" ]]; then
        cmd+=(--project-id "${project_id}")
      fi
      if [[ -n "${screen_ref}" ]]; then
        cmd+=(--screen-ref "${screen_ref}")
      fi
      if [[ -n "${artifact}" ]]; then
        cmd+=(--artifact "${artifact}")
      fi
      if [[ -n "${prompt}" ]]; then
        cmd+=(--prompt "${prompt}")
      fi
      "${cmd[@]}"
      ;;
    *)
      fail "Unsupported stitch-state subcommand: ${subcommand}"
      ;;
  esac
}
chunk_write_command() {
  local target_file=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --file)
        [[ "$#" -ge 2 ]] || fail "Missing value for --file"
        target_file="$2"
        shift 2
        ;;
      *)
        fail "Unknown argument: $1"
        ;;
    esac
  done

  [[ -n "${target_file}" ]] || fail "Missing required argument: --file"

  mkdir -p "$(dirname "${target_file}")"

  # Consume standard input and append to the target file
  # This helper bypasses typical text editor tooling token limits
  local buffer=""
  while IFS= read -r line; do
    printf "%s\\n" "$line" >> "${target_file}"
  done
  # read the last line if it's missing a newline
  if [[ -n "$line" ]]; then
    printf "%s" "$line" >> "${target_file}"
  fi

  printf "Successfully chunk-appended to %s\\n" "${target_file}"
}

main() {
  local command="${1:-}"
  shift || true

  case "${command}" in
    doctor)
      doctor_command "$@"
      ;;
    update)
      [[ "$#" -eq 0 ]] || fail "Unsupported arguments for 'update'"
      update_command
      ;;
    resolve)
      resolve_command "$@"
      ;;
    next)
      next_command "$@"
      ;;
    check-prereq)
      check_prereq_command "$@"
      ;;
    template-section)
      template_section_command "$@"
      ;;
    source-extract)
      source_extract_command "$@"
      ;;
    design-snapshot)
      design_snapshot_command "$@"
      ;;
    stitch-state)
      stitch_state_command "$@"
      ;;
    chunk-write)
      chunk_write_command "$@"
      ;;
    status)
      status_command "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      fail "Unknown command: ${command}"
      ;;
  esac
}

main "$@"
